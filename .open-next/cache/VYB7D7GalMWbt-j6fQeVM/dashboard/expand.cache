st_mono_8d43a2aa-module__8Li5zG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen bg-muted/10 pb-20\"><div class=\"sticky top-0 z-50 w-full border-b border-white/20 bg-white/70 shadow-sm backdrop-blur-xl dark:border-white/10 dark:bg-zinc-900/70\"><div class=\"container mx-auto flex h-16 items-center justify-between px-4\"><div class=\"flex items-center gap-6\"><div class=\"hidden md:block\"><h1 class=\"bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-xl font-bold tracking-tight text-transparent dark:from-indigo-400 dark:to-violet-400\">关键词研究台</h1></div><nav class=\"flex items-center gap-1\"><a class=\"relative rounded-full px-4 py-1.5 text-sm font-medium transition-colors hover:text-primary bg-primary/10 text-primary\" href=\"/dashboard/expand\">1. 词根扩展</a><a class=\"relative rounded-full px-4 py-1.5 text-sm font-medium transition-colors hover:text-primary text-muted-foreground hover:bg-muted\" href=\"/dashboard/candidates\">2. 候选筛选</a><a class=\"relative rounded-full px-4 py-1.5 text-sm font-medium transition-colors hover:text-primary text-muted-foreground hover:bg-muted\" href=\"/dashboard/analysis\">3. 趋势对比</a><a class=\"relative rounded-full px-4 py-1.5 text-sm font-medium transition-colors hover:text-primary text-muted-foreground hover:bg-muted\" href=\"/dashboard/discovery\">新游发现</a></nav></div><div class=\"flex items-center gap-2\"><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-loader-circle h-4 w-4 animate-spin text-muted-foreground\" aria-hidden=\"true\"><path d=\"M21 12a9 9 0 1 1-6.219-8.56\"></path></svg><span class=\"text-xs text-muted-foreground\">检查登录状态...</span></div></div></div></div><main class=\"container mx-auto max-w-7xl px-4 py-8\"><div class=\"space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-500\"><div class=\"rounded-xl border border-zinc-200 bg-card text-card-foreground shadow-sm transition-all hover:shadow-md dark:border-zinc-800 hover:border-primary/20 hover:shadow-primary/5\"><div class=\"flex flex-col space-y-1.5 p-6\"><div class=\"flex flex-col gap-4 md:flex-row md:items-start md:justify-between\"><div><h3 class=\"font-semibold leading-none tracking-tight\">第一步：词根扩展</h3><p class=\"text-sm text-muted-foreground\">设置种子词和过滤条件，系统会基于趋势相关词生成候选关键词。</p></div><div class=\"flex flex-wrap items-center gap-4 text-sm text-muted-foreground\"><label class=\"flex cursor-pointer items-center gap-2 transition-colors hover:text-foreground\"><input type=\"checkbox\" class=\"rounded border-zinc-300 text-primary focus:ring-ring\" checked=\"\"/>使用缓存</label><label class=\"flex cursor-pointer items-center gap-2 transition-colors hover:text-foreground\"><input type=\"checkbox\" class=\"rounded border-zinc-300 text-primary focus:ring-ring\"/>保留 Top 词</label><label class=\"flex cursor-pointer items-center gap-2 transition-colors hover:text-foreground\"><input type=\"checkbox\" class=\"rounded border-zinc-300 text-primary focus:ring-ring\" checked=\"\"/>启用语义过滤</label></div></div></div><div class=\"p-6 pt-0 space-y-4\"><div class=\"text-sm text-muted-foreground\">预计成本：<span class=\"ml-1 font-medium text-foreground\">$0.50</span><span class=\"ml-1 text-xs\">（<!-- -->10<!-- --> 个词根 × <!-- -->$0.05<!-- -->）</span></div><div class=\"grid gap-4 md:grid-cols-2\"><div class=\"space-y-2\"><label class=\"text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70\">黑名单主题</label><textarea class=\"flex w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50 min-h-[80px]\" placeholder=\"输入要排除的主题，例如：博彩、影视、新闻、登录页\">gambling,betting,casino,news,celebrity,movie,film,lottery,gold,gold price,stock market,stock trading,stock price,stocks,equity,equities,futures,futures market,futures trading,login,log in,log-in,signin,sign in,sign-in,signup,sign up,sign-up,register,registration,portal,ice agent,cartel,ambush,ambushed,博彩,赌博,赌场,投注,新闻,名人,电影,黄金,金价,股市,股票,证券,期货,期货交易,期货市场,交易市场,登录,登陆,注册,门户,门户网站,ice特工</textarea></div><div class=\"space-y-2\"><label class=\"text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70\">补充过滤提示</label><textarea class=\"flex w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50 min-h-[80px]\" placeholder=\"可选。用于补充模型过滤规则，例如：排除所有资讯聚合页和品牌词\"></textarea></div></div><div class=\"space-y-2\"><label class=\"text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70\">核心词根</label><textarea class=\"flex w-full rounded-md border border-input bg-transparent px-3 py-2 shadow-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50 min-h-[120px] font-mono text-sm\" placeholder=\"输入词根，支持逗号、空格、换行分隔\"></textarea><div class=\"flex items-center justify-between text-xs text-muted-foreground\"><span>默认词根：<!-- -->calculator, generator, converter, maker, creator<!-- -->...</span></div></div></div><div class=\"items-center p-6 flex flex-col gap-3 border-t bg-muted/50 px-6 py-4\"><div class=\"flex w-full items-center justify-between\"><div></div><div class=\"flex items-center gap-4\"><button class=\"inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground shadow hover:bg-primary/90 h-9 px-4 py-2\">获取候选词</button></div></div></div></div><div class=\"rounded-lg border border-dashed p-4 text-sm text-muted-foreground\">点击“获取候选词”后，系统会完成扩词并自动进入下一步筛选。</div></div><!--$--><!--/$--></main><div class=\"fixed inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-100/20 via-background to-background dark:from-indigo-950/20\"></div></div><script src=\"/_next/static/chunks/d5d057d618e71fae.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n4:I[92825,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"ClientSegmentRoot\\\"]\\n5:I[82391,[\\\"/_next/static/chunks/d7708fb08bd05386.js\\\",\\\"/_next/static/chunks/7212b06c7cf5ab04.js\\\"],\\\"default\\\"]\\n7:I[47257,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"ClientPageRoot\\\"]\\n8:I[84938,[\\\"/_next/static/chunks/d7708fb08bd05386.js\\\",\\\"/_next/static/chunks/7212b06c7cf5ab04.js\\\",\\\"/_next/static/chunks/9e4deb5b0a02d496.js\\\"],\\\"default\\\"]\\nb:I[97367,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"OutletBoundary\\\"]\\nc:\\\"$Sreact.suspense\\\"\\ne:I[97367,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"ViewportBoundary\\\"]\\n10:I[97367,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"MetadataBoundary\\\"]\\n12:I[68027,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n:HL[\